# Installed fresh in the image
node_modules

# Never bake secrets into the image — set them with `fly secrets set`
.env
.env.*

# Web-app build output (the daemon doesn't need it)
.next
out

# VCS / tooling
.git
.gitignore

# Docs, planning, and eval fixtures are not needed at runtime.
# NOTE: compliance-prompt.md and lib/examples/*.md ARE needed and are NOT excluded.
docs
.planning
evals
*.log
